le değiştirildi","scope":"language-overridable"},"javascript.preferences.useAliasesForRenames":{"type":"boolean","default":true,"description":"Yeniden adlandırmalar sırasında nesne steno özellikleri için takma adların tanıtılmasını etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"typescript.preferences.useAliasesForRenames":{"type":"boolean","default":true,"description":"Yeniden adlandırmalar sırasında nesne steno özellikleri için takma adların tanıtılmasını etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"javascript.preferences.renameMatchingJsxTags":{"type":"boolean","default":true,"description":"Bir JSX etiketi üzerindeyken, sembolü yeniden adlandırmak yerine eşleşen etiketi yeniden adlandırmayı deneyin. Çalışma alanında TypeScript 5.1+ kullanmayı gerektirir.","scope":"language-overridable"},"typescript.preferences.renameMatchingJsxTags":{"type":"boolean","default":true,"description":"Bir JSX etiketi üzerindeyken, sembolü yeniden adlandırmak yerine eşleşen etiketi yeniden adlandırmayı deneyin. Çalışma alanında TypeScript 5.1+ kullanmayı gerektirir.","scope":"language-overridable"},"typescript.preferences.organizeImports":{"type":"object","markdownDescription":"İçeri aktarmaların nasıl sıralanacağını denetleyen gelişmiş tercihler.","properties":{"caseSensitivity":{"type":"string","enum":["auto","caseInsensitive","caseSensitive"],"markdownEnumDescriptions":["İçeri aktarma sıralaması için büyük/küçük harf duyarlılığını algıla.","%typescript.preferences.organizeImports.caseSensitivity.insensitive","İçeri aktarmaları büyük/küçük harfe duyarlı olarak sırala."],"default":"auto"},"typeOrder":{"type":"string","enum":["auto","last","inline","first"],"default":"auto","markdownEnumDescriptions":["Yalnızca türü adlandırılmış içeri aktarmaların nerede sıralanacağı algıla.","Yalnızca türü adlandırılmış içeri aktarmalar, içeri aktarma listesinin sonuna sıralanır.","Adlandırılmış içeri aktarmalar yalnızca ada göre sıralanır.","Yalnızca türü adlandırılmış içeri aktarmalar, içeri aktarma listesinin sonuna sıralanır."]},"unicodeCollation":{"type":"string","enum":["ordinal","unicode"],"markdownEnumDescriptions":["İçeri aktarmaları her kod noktasının sayısal değerini kullanarak sırala.","İçeri aktarmaları Unicode kod harmanlaması kullanarak sırala."],"default":"ordinal"},"locale":{"type":"string","markdownDescription":"Harmanlama için kullanılan yerel ayarı geçersiz kılar. UI yerel ayarlarını kullanmak için 'auto' değerini belirtin. Yalnızca `organizeImportsCollation: 'unicode'` için geçerlidir."},"numericCollation":{"type":"boolean","markdownDescription":"Sayısal dizeleri tamsayı değerine göre sırala."},"accentCollation":{"type":"boolean","markdownDescription":"Aksanlı karakterleri taban karakterle eşit olmayacak şekilde karşılaştır."},"caseFirst":{"type":"string","markdownDescription":"Büyük harflerin küçük harflerden önce gelip gelmeyeceğini gösterir. Yalnızca `organizeImportsCollation: 'unicode'` için geçerlidir.","enum":["default","upper","lower"],"default":"default"}}},"javascript.preferences.organizeImports":{"type":"object","markdownDescription":"İçeri aktarmaların nasıl sıralanacağını denetleyen gelişmiş tercihler.","properties":{"caseSensitivity":{"type":"string","enum":["auto","caseInsensitive","caseSensitive"],"markdownEnumDescriptions":["İçeri aktarma sıralaması için büyük/küçük harf duyarlılığını algıla.","%typescript.preferences.organizeImports.caseSensitivity.insensitive","İçeri aktarmaları büyük/küçük harfe duyarlı olarak sırala."],"default":"auto"},"typeOrder":{"type":"string","enum":["auto","last","inline","first"],"default":"auto","markdownEnumDescriptions":["Yalnızca türü adlandırılmış içeri aktarmaların nerede sıralanacağı algıla.","Yalnızca türü adlandırılmış içeri aktarmalar, içeri aktarma listesinin sonuna sıralanır.","Adlandırılmış içeri aktarmalar yalnızca ada göre sıralanır.","Yalnızca türü adlandırılmış içeri aktarmalar, içeri aktarma listesinin sonuna sıralanır."]},"unicodeCollation":{"type":"string","enum":["ordinal","unicode"],"markdownEnumDescriptions":["İçeri aktarmaları her kod noktasının sayısal değerini kullanarak sırala.","İçeri aktarmaları Unicode kod harmanlaması kullanarak sırala."],"default":"ordinal"},"locale":{"type":"string","markdownDescription":"Harmanlama için kullanılan yerel ayarı geçersiz kılar. UI yerel ayarlarını kullanmak için 'auto' değerini belirtin. Yalnızca `organizeImportsCollation: 'unicode'` için geçerlidir."},"numericCollation":{"type":"boolean","markdownDescription":"Sayısal dizeleri tamsayı değerine göre sırala."},"accentCollation":{"type":"boolean","markdownDescription":"Aksanlı karakterleri taban karakterle eşit olmayacak şekilde karşılaştır."},"caseFirst":{"type":"string","markdownDescription":"Büyük harflerin küçük harflerden önce gelip gelmeyeceğini gösterir. Yalnızca `organizeImportsCollation: 'unicode'` için geçerlidir.","enum":["default","upper","lower"],"default":"default"}}},"typescript.updateImportsOnFileMove.enabled":{"type":"string","enum":["prompt","always","never"],"markdownEnumDescriptions":["Her yeniden adlandırmada sor.","Yolları her zaman otomatik olarak güncelleştirin.","Yolları hiçbir zaman yeniden adlandırma ve sorma."],"default":"prompt","description":"VS Code içinde bir dosyayı yeniden adlandırdığınızda veya taşıdığınızda içeri aktarma yollarının otomatik olarak güncelleştirilmesini etkinleştirin/devre dışı bırakın.","scope":"resource"},"javascript.updateImportsOnFileMove.enabled":{"type":"string","enum":["prompt","always","never"],"markdownEnumDescriptions":["Her yeniden adlandırmada sor.","Yolları her zaman otomatik olarak güncelleştirin.","Yolları hiçbir zaman yeniden adlandırma ve sorma."],"default":"prompt","description":"VS Code içinde bir dosyayı yeniden adlandırdığınızda veya taşıdığınızda içeri aktarma yollarının otomatik olarak güncelleştirilmesini etkinleştirin/devre dışı bırakın.","scope":"resource"},"typescript.autoClosingTags":{"type":"boolean","default":true,"description":"JSX etiketlerinin otomatik kapatılmasını etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"javascript.autoClosingTags":{"type":"boolean","default":true,"description":"JSX etiketlerinin otomatik kapatılmasını etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"javascript.suggest.enabled":{"type":"boolean","default":true,"description":"Otomatik tamamlama önerilerini etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"typescript.suggest.enabled":{"type":"boolean","default":true,"description":"Otomatik tamamlama önerilerini etkinleştirin/devre dışı bırakın.","scope":"language-overridable"},"typescript.surveys.enabled":{"type":"boolean","default":true,"description":"Zaman zaman gerçekleştirilen, VS Code'un JavaScript ve TypeScript desteğini geliştirmemize yardımcı olan anketleri etkinleştirin/devre dışı bırakın.","scope":"window"},"typescript.tsserver.useSeparateSyntaxServer":{"type":"boolean","default":true,"description":"Katlama hesaplama veya belge sembollerini hesaplama gibi sözdizimiyle ilgili işlemlere daha hızlı yanıt verebilen ayrı bir TypeScript sunucusu oluşturmayı etkinleştirin/devre dışı bırakın.","markdownDeprecationMessage":"Bu ayar 'typescript.tsserver.useSyntaxServer' için kullanım dışı bırakıldı.","scope":"window"},"typescript.tsserver.useSyntaxServer":{"type":"string","scope":"window","description":"TypeScript'in, kod katlama gibi söz dizimi ile ilgili işlemleri daha hızlı yürütmek için, ayrılmış bir sunucu başlatıp başlatmadığını kontrol eder.","default":"auto","enum":["always","never","auto"],"enumDescriptions":["Tüm IntelliSense işlemlerini yürütmek için daha hafif bir sözdizimi sunucusu kullanın. Bu sözdizimi sunucusu, yalnızca açılan dosyalar için IntelliSense özelliği sağlayabilir.","Ayrılmış bir sözdizimi sunucusu kullanmayın. Tüm IntelliSense işlemlerini yürütmek için tek sunucu kullanın.","Hem tam bir sunucu hem de sözdizimi işlemlerine ayrılmış daha hafif bir sunucu oluşturun. Sözdizimi sunucusu, sözdizimi işlemlerini hızlandırmak ve projeler yüklenirken IntelliSense sağlamak için kullanılır."]},"typescript.tsserver.maxTsServerMemory":{"type":"number","default":3072,"markdownDescription":"TypeScript sunucu işlemine ayrılacak bellek miktarı üst sınırı (MB cinsinden). 4 GB'tan büyük bir bellek sınırı kullanmak için `#typescript.tsserver.nodePath#` kullanarak TS Sunucusunu özel bir Düğüm yüklemesi ile çalıştırın.","scope":"window"},"typescript.tsserver.experimental.enableProjectDiagnostics":{"type":"boolean","default":false,"description":"(Deneysel) Proje genelinde hata raporlaması sağlar.","scope":"window","tags":["experimental"]},"typescript.tsserver.experimental.useVsCodeWatcher":{"type":"boolean","description":"TypeScript'in yerine VS Code'un dosya izleyicilerini kullanın. Çalışma alanında TypeScript 5.4+ kullanmayı gerektirir.","default":true},"typescript.tsserver.watchOptions":{"type":"object","description":"Dosyaları ve dizinleri takip etmek için hangi izleme stratejilerinin kullanılması gerektiğini yapılandırın.","scope":"window","properties":{"watchFile":{"type":"string","description":"Tek tek dosyaların izlenmesine yönelik strateji.","enum":["fixedChunkSizePolling","fixedPollingInterval","priorityPollingInterval","dynamicPriorityPolling","useFsEvents","useFsEventsOnParentDirectory"],"enumDescriptions":["Dosyaları düzenli aralıklarla parçalar halinde yoklar.","Her dosyayı sabit bir zaman aralığında saniyede birkaç kez değişiklikler için denetleyin.","Her dosyayı saniyede birkaç kez değişiklikler için denetleyin, ancak bazı dosya türlerini diğerlerine göre daha az sıklıkla denetlemek için buluşsal yöntemleri kullanın.","Daha az değiştirilen dosyaların daha az sıklıkta denetlendiği bir dinamik kuyruk kullanın.","Dosya değişiklikleri için işletim sisteminin/dosya sisteminin yerel olaylarını kullanmaya çalışma.","Bir dosyanın bulunduğu dizinlerdeki değişiklikleri dinlemek için işletim sisteminin/dosya sisteminin yerel olaylarını kullanmaya çalışma. Bu, daha az dosya izleyicisi kullanabilir, ancak daha az doğru olabilir."],"default":"useFsEvents"},"watchDirectory":{"type":"string","description":"Özyinelemeli dosya izleme işlevi olmayan sistemler altında tüm dizin ağaçlarının izlenmesine yönelik strateji.","enum":["fixedChunkSizePolling","fixedPollingInterval","dynamicPriorityPolling","useFsEvents"],"enumDescriptions":["Düzenli aralıklarla parçalar halinde anketler dizinleri.","Her dizini sabit bir zaman aralığında saniyede birkaç kez değişiklikler için denetleyin.","Daha az değiştirilen dizinlerin daha az sıklıkta denetlendiği dinamik bir kuyruk kullanın.","Dizin değişiklikleri için işletim sisteminin/dosya sisteminin yerel olaylarını kullanmaya çalışma."],"default":"useFsEvents"},"fallbackPolling":{"type":"string","description":"Bu seçenek, dosya sistemi olayları kullanılırken, sistemde yerel dosya izleyicileri tükendiğinde ve/veya sistem yerel dosya izleyicilerini desteklemediğinde kullanılan yoklama stratejisini belirtir.","enum":["fixedPollingInterval","priorityPollingInterval","dynamicPriorityPolling"],"enumDescriptions":["configuration.tsserver.watchOptions.fallbackPolling.fixedPollingInterval","configuration.tsserver.watchOptions.fallbackPolling.priorityPollingInterval","configuration.tsserver.watchOptions.fallbackPolling.dynamicPriorityPolling"]},"synchronousWatchDirectory":{"type":"boolean","description":"Dizinlerde ertelenmiş izlemeyi devre dışı bırakın. Çok sayıda dosya değişikliği aynı anda gerçekleşebildiğinde ertelenmiş izleme yararlıdır (örneğin npm yüklemesinden node_modules içindeki bir değişiklik), ancak daha az yaygın kurulumlar için bu bayrağı devre dışı bırakmak isteyebilirsiniz."}}},"typescript.workspaceSymbols.scope":{"type":"string","enum":["allOpenProjects","currentProject"],"enumDescriptions":["Semboller için tüm açık JavaScript veya TypeScript projelerini arayın.","Yalnızca geçerli JavaScript veya TypeScript projesindeki sembolleri arayın."],"default":"allOpenProjects","markdownDescription":"Hangi dosyaların [Çalışma Alanında Sembole Git](https://code.visualstudio.com/docs/editor/editingevolved#_open-symbol-by-name) seçeneğiyle arandığını denetler.","scope":"window"},"javascript.suggest.classMemberSnippets.enabled":{"type":"boolean","default":true,"description":"Sınıf üyeleri için snippet tamamlamalarını etkinleştirme/devre dışı bırakma.","scope":"resource"},"typescript.suggest.classMemberSnippets.enabled":{"type":"boolean","default":true,"description":"Sınıf üyeleri için snippet tamamlamalarını etkinleştirme/devre dışı bırakma.","scope":"resource"},"typescript.suggest.objectLiteralMethodSnippets.enabled":{"type":"boolean","default":true,"description":"Nesne değişmezlerindeki yöntemler için snippet tamamlamalarını etkinleştirin/devre dışı bırak.","scope":"resource"},"typescript.tsserver.web.projectWideIntellisense.enabled":{"type":"boolean","default":true,"description":"Web üzerinde proje genelinde IntelliSense'i etkinleştirin/devre dışı bırakın. VS Code'un güvenilen bir bağlamda çalıştırılmasını gerektirir.","scope":"window"},"typescript.tsserver.web.projectWideIntellisense.suppressSemanticErrors":{"type":"boolean","default":false,"description":"Proje genelinde IntelliSense etkinleştirildiğinde bile webde semantik hataları gizler. Proje genelinde IntelliSense etkinleştirilmediğinde veya kullanılabilir olduğunda bu her zaman açıktır. Bkz. `#typescript.tsserver.web.projectWideIntellisense.enabled#`","scope":"window"},"typescript.tsserver.web.typeAcquisition.enabled":{"type":"boolean","default":true,"description":"Web'de paket alımını etkinleştirin/devre dışı bırakın. Bu, içeri aktarılan paketler için IntelliSense'i etkinleştirir. `#typescript.tsserver.web.projectWideIntellisense.enabled#` gerektirir. Şu anda Safari için desteklenmiyor.","scope":"window"},"typescript.tsserver.nodePath":{"type":"string","description":"TS Sunucusunu özel bir Node kurulumunda çalıştırın. Bu, çalıştırılabilir bir Node'a giden yol olabilir veya VS Code'un bir Node kurulumunu algılamasını istiyorsanız 'düğüm' olabilir.","scope":"window"},"typescript.preferGoToSourceDefinition":{"type":"boolean","default":false,"description":"Mümkünse, bunun yerine Kaynak Tanımına Git komutunu tetikleyerek Tanıma Git komutunun tür bildirimi dosyalarından kaçınmasını sağlar. Bu, Kaynak Tanımına Git komutunun fare hareketiyle tetiklenmesine olanak tanır.","scope":"window"},"javascript.preferGoToSourceDefinition":{"type":"boolean","default":false,"description":"Mümkünse, bunun yerine Kaynak Tanımına Git komutunu tetikleyerek Tanıma Git komutunun tür bildirimi dosyalarından kaçınmasını sağlar. Bu, Kaynak Tanımına Git komutunun fare hareketiyle tetiklenmesine olanak tanır.","scope":"window"},"typescript.workspaceSymbols.excludeLibrarySymbols":{"type":"boolean","default":true,"markdownDescription":"Çalışma Alanında Sembole Git sonuçlarında kitaplık dosyalarından gelen simgeleri hariç tut. Çalışma alanında TypeScript 5.3+ kullanmayı gerektirir.","scope":"window"},"typescript.tsserver.enableRegionDiagnostics":{"type":"boolean","default":true,"description":"TypeScript’te bölge tabanlı tanılamaya olanak sağlar. Çalışma alanında TypeScript 5.6+ kullanmayı gerektirir.","scope":"window"},"javascript.experimental.updateImportsOnPaste":{"scope":"window","type":"boolean","default":false,"description":"Kodu yapıştırırken içeri aktarmaları otomatik olarak güncelleştirin. TypeScript 5.6+ gerektirir.","tags":["experimental"]},"typescript.experimental.updateImportsOnPaste":{"scope":"window","type":"boolean","default":false,"description":"Kodu yapıştırırken içeri aktarmaları otomatik olarak güncelleştirin. TypeScript 5.6+ gerektirir.","tags":["experimental"]},"typescript.experimental.expandableHover":{"type":"boolean","default":false,"description":"(Experimental) Enable/disable expanding on hover.","scope":"window","tags":["experimental"]}}},"commands":[{"command":"typescript.reloadProjects","title":{"value":"Projeyi Yeniden Yükle","original":"Reload Project"},"catego