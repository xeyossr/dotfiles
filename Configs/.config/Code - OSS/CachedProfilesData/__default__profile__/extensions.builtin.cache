ere on disk logs are written.","type":["string","null"]},"stdio":{"description":"Whether to return trace data from the launched application or browser.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Geçerli çağrı yığınına yol açan asenkron çağrıları gösterin.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Hata ayıklama sırasında atlanması Hata ayıklama sırasında atlanacak bir dizi dosya veya klasör adı veya yol glob'u. Yıldız kalıplarına ve olumsuzlamalara izin verilir, örneğin, `[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]`için dosya veya klasör adları veya yol globları dizisi. Yıldız desenlerine ve olumsuzluklara izin verilir; örneğin, '[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]'","type":"array"},"smartStep":{"default":true,"description":"Özgün kaynağa geri eşlenemeyen durumdaki oluşturulan kodu otomatik olarak adımlayın.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Kaynak dosyalarını, kaynak eşlemesinde belirtilen konumlardan dosyaların diskteki konumlarına yeniden yazmak için eşleme kümesi.","type":"object"},"sourceMapRenames":{"default":true,"description":"Kaynak eşlemelerinde \"names\" eşlemesinin kullanılıp kullanılmayacağı. Bu, kaynak içerik istemeyi gerektirir ve bazı hata ayıklayıcılarıyla yavaş çalışabilir.","type":"boolean"},"sourceMaps":{"default":true,"description":"(Varsa) JavaScript kaynak eşlemelerini kullanın.","type":"boolean"},"targetSelection":{"default":"automatic","enum":["pick","automatic"],"markdownDescription":"URL filtresiyle eşleşen (\"otomatik\") tüm hedeflere eklenip eklenmeyeceğini (\"seç\") belirtir.","type":"string"},"timeout":{"default":10000,"description":"Node.js'ye bağlanmak için bu kadar milisaniye boyunca yeniden dene. Varsayılan: 10.000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","markdownDescription":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","properties":{"hoverEvaluation":{"default":500,"description":"Üzerine gelinen sembollerin değerinin değerlendirilmesine kadar geçen süre kesintiye uğradı. 0 olarak ayarlanırsa, üzerine gelme değerlendirmesi asla zaman aşımına uğramaz.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Minimum süre (sourceMapMinPause) dolduktan sonra kaynak eşlemelerinin işlenmesini beklerken harcanacak oturum başına izin verilen ek süre (milisaniye cinsinden)","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Betik ayrıştırıldığında her kaynak eşlemesinin işlenmesi için harcanan minimum süre (milisaniye cinsinden)","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Configures what diagnostic output is produced.","oneOf":[{"description":"Trace may be set to 'true' to write diagnostic logs to the disk.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Configures where on disk logs are written.","type":["string","null"]},"stdio":{"description":"Whether to return trace data from the launched application or browser.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tam olarak bu URL'ye sahip bir sekme arayacak ve bulunursa ona eklenecek","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Bu URL'yi içeren bir sayfa arar ve bulunursa sayfaya ekler. * joker karakterler içerebilir.","type":"string"},"useWebView":{"default":{"pipeName":"MyPipeName"},"description":"UWP tarafından barındırılan Webview2 için bir hata ayıklama kanalının \"pipeName\" adını içeren bir nesne. Bu, \"\\\\.\\pipe\\LOCAL\\MyTestSharedMemory\" kanalını oluştururken \"MyTestSharedMemory\"dir.","properties":{"pipeName":{"type":"string"}},"type":"object"},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"`*.vue` bileşenlerini bulmaya yönelik dosya glob desenlerinin listesi. Varsayılan olarak, tüm çalışma alanını arar. Vue'nun kaynak eşlemelerinin Vue CLI 4'te gerektirdiği ek aramalar nedeniyle bunun belirtilmesi gerekir. Bunu boş bir diziye ayarlayarak bu özel işlemeyi devre dışı bırakabilirsiniz.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Bu, web sunucusu kökü için çalışma alanı mutlak yolunu belirtir. `/app.js` gibi yolları diskte dosyalara çözümlemek için kullanılır. \"/\" için pathMapping öğesine yönelik kısaltma","tags":["setup"],"type":"string"}}},"launch":{"properties":{"address":{"default":"localhost","description":"Web görünümlerinde hata ayıklarken web görünümünün dinlediği IP adresi veya konak adı. Ayarlanmazsa otomatik olarak bulunur.","type":"string"},"browserLaunchLocation":{"default":null,"description":"Tarayıcının tek bir yerde başlatılmasını zorlar. Uzak bir çalışma alanında (örneğin ssh veya WSL aracılığıyla) tarayıcıyı yerel olarak değil uzak makinede açmak için bu kullanılabilir.","oneOf":[{"type":"null"},{"enum":["ui","workspace"],"type":"string"}]},"cascadeTerminateToConfigurations":{"default":[],"description":"Bu hata ayıklama oturumu sonlandırıldığında durdurulacak hata ayıklama oturumlarının listesi.","items":{"type":"string","uniqueItems":true},"type":"array"},"cleanUp":{"default":"wholeBrowser","description":"Hata ayıklama oturumu bittikten sonra yapılacak temizleme. Yalnızca hata ayıklanan sekmeyi kapatın veya tüm tarayıcıyı kapatın.","enum":["wholeBrowser","onlyTab"],"type":"string"},"customDescriptionGenerator":{"description":"Hata ayıklayıcısının nesneler (yerel değişkenler vb.) için gösterdiği metinsel açıklamayı özelleştirin. Örnekler:\r\n      1. this.toString () // tüm nesneleri yazdırmak için toString çağırır\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n      3. işlev (def) { return this.customDescription ? this.customDescription() : def } // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n     ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Hata ayıklamada bir nesne için gösterilen özellikleri özelleştirin (yerel değişkenler, vb...). Örnekler:\r\n    1. { ...this, extraProperty: '12345' } // Tüm nesnelere extraProperty 12345 ekleyin\r\n    2. this.customProperties ? this.customProperties() : this // Varsa customProperties yöntemini kullanın, yoksa buradaki özellikleri kullanın (varsayılan özellikler)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Varsa customDescription yöntemini kullanın, yoksa varsayılan özellikleri döndürün\r\n\r\n    Kullanım dışı: Bu, burada açıklanan şekilde uygulanana kadar bu özelliğin geçici bir uygulamasıdır: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":null,"description":"Çalışma zamanı yürütülebilir dosyası için isteğe bağlı çalışma dizini.","type":"string"},"disableNetworkCache":{"default":true,"description":"Her istek için ağ önbelleğinin atlanıp atlanmayacağını denetler","type":"boolean"},"enableContentValidation":{"default":true,"description":"Diskteki dosyaların içeriklerinin çalışma zamanında yüklenenlerle eşleşip eşleşmediğini doğrulayıp doğrulamadığımızı belirtir. Bu, çeşitli senaryolarda kullanışlıdır ve bazılarında gereklidir ancak örneğin, betiklerin sunucu tarafında dönüşümüne sahipseniz sorunlara neden olabilir.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Hata ayıklayıcının, kaynak kullanımı yoğun olan WebAssembly'den DWARF hata ayıklama sembollerini okumayı deneyip denemeyeceğini değiştirir. İşlev için 'ms-vscode.wasm-debugging' uzantısını gerektirir.","type":"boolean"},"env":{"default":{},"description":"Optional dictionary of environment key/value pairs for the browser.","type":"object"},"file":{"default":"${workspaceFolder}/index.html","description":"Tarayıcıda açmak için bir yerel html dosyası","tags":["setup"],"type":"string"},"includeDefaultArgs":{"default":true,"description":"Whether default browser launch arguments (to disable features that may make debugging harder) will be included in the launch.","type":"boolean"},"includeLaunchArgs":{"default":true,"description":"Gelişmiş: tarayıcıda herhangi bir varsayılan başlatma/hata ayıklama bağımsız değişkeninin ayarlanıp ayarlanmadığı. Hata ayıklayıcı, tarayıcının \"--remote-debugging-pipe\" ile sağlananlar gibi boru hata ayıklamasını kullanacağını varsayacaktır.","type":"boolean"},"inspectUri":{"default":null,"description":"InspectUri'yi yeniden yazmak için kullanılacak biçim: `{curlyBraces}` içinde anahtarları ilişkilendiren bir şablon dizesidir. Kullanılabilir anahtarlar şunlardır: \r\n- `url.*` çalışan uygulamanın ayrıştırılmış adresidir. Örneğin, `{url.port}`, `{url.hostname}\r\n`- `port` Chrome'un dinlediği hata ayıklama bağlantı noktasıdır.\r\n - `browserInspectUri` başlatılan tarayıcıda denetim URI'sidir\r\n - `browserInspectUriPath` başlatılan tarayıcıda denetim URI'sinin yol bölümüdür (örn: \"/devtools/browser/e9ec0098-306e-472a-8133-5e42488929c2\").\r\n - `wsProtocol` ima edilen web yuvası protokolüdür. Orijinal URL `https` ise `wss`, aksi takdirde `ws` olarak ayarlanır.\r\n","type":["string","null"]},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Kaynak eşlemeleri etkinse bu glob desenleri, oluşturulan JavaScript dosyalarını belirtir. Bir desen `!` ile başlarsa dosyalar hariç tutulur. Belirtilmezse, oluşturulan kodun, kaynağıyla aynı dizinde olması beklenir.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Çıkış iletilerinin yakalanacağı konum: `Konsol` olarak ayarlanırsa varsayılan hata ayıklama API'si veya `std `olarak ayarlanırsa stdout/stderr akışları."},"pathMapping":{"default":{},"description":"A mapping of URLs/paths to local folders, to resolve scripts in the Browser to scripts on disk","type":"object"},"pauseForSourceMap":{"default":false,"markdownDescription":"Whether to wait for source maps to load for each incoming script. This has a performance overhead, and might be safely disabled when running off of disk, so long as `rootPath` is not disabled.","type":"boolean"},"perScriptSourcemaps":{"default":"auto","description":"Betiklerin, kaynak dosyanın temel adını içeren benzersiz kaynak eşlemeleri ile tek tek yüklenip yüklenmediğini belirtir. Bu, çok sayıda küçük betik ile çalışırken kaynak eşlemesini iyileştirmek için ayarlanabilir. \"Otomatik\" olarak ayarlanırsa bunun uygun olduğu bilinen durumları algılarız.","enum":["yes","no","auto"],"type":"string"},"port":{"default":9229,"description":"Web görünümlerinde hata ayıklarken, web görünümü hata ayıklayıcısının dinlediği bağlantı noktası. Ayarlanmazsa otomatik olarak bulunur.","type":"number"},"profileStartup":{"default":true,"description":"True ise, işlem başlatıldıktan hemen sonra profil oluşturulmaya başlanır","type":"boolean"},"resolveSourceMapLocations":{"default":null,"description":"A list of minimatch patterns for locations (folders and URLs) in which source maps can be used to resolve local files. This can be used to avoid incorrectly breaking in external source mapped code. Patterns can be prefixed with \"!\" to exclude them. May be set to an empty array or null to avoid restriction.","items":{"type":"string"},"type":["array","null"]},"runtimeArgs":{"default":[],"description":"Çalışma zamanı yürütülebilir dosyasına geçirilen isteğe bağlı bağımsız değişkenler.","items":{"type":"string"},"type":"array"},"runtimeExecutable":{"default":"stable","description":"'Kanarya', 'kararlı', 'özel' veya tarayıcı yürütülebilir dosyasının yolu. Özel ifadesi özel bir sarmalayıcı, özel yapı veya EDGE_PATH ortam değişkeni anlamına gelir.","type":["string","null"]},"server":{"oneOf":[{"additionalProperties":false,"default":{"program":"node my-server.js"},"description":"Configures a web server to start up. Takes the same configuration as the 'node' launch task.","properties":{"args":{"default":[],"description":"Programa geçirilen komut satırı bağımsız değişkenleri.\r\n\r\nBir dizi veya tek bir dize olabilir. Program bir terminalde başlatıldığında bu özelliğin tek bir dize olarak ayarlanması bağımsız değişkenlerin kabuk için kaçamamasına neden olur.","items":{"type":"string"},"tags":["setup"],"type":["array","string"]},"attachSimplePort":{"default":9229,"description":"Ayarlanırsa, işleme verilen bağlantı noktası üzerinden eklenir. Bu genellikle Node.js programları için artık gerekli değildir ve alt işlemlerde hata ayıklama özelliğini kaybeder ancak Deno ve Docker başlatmaları gibi daha gizli senaryolarda yararlı olabilir. 0 olarak ayarlanırsa, rastgele bir bağlantı noktası seçilir ve başlatma bağımsız değişkenlerine otomatik olarak --inspect-brk eklenir.","oneOf":[{"type":"integer"},{"pattern":"^\\${.*}$","type":"string"}]},"autoAttachChildProcesses":{"default":true,"description":"Hata ayıklayıcıyı yeni alt işlemlere otomatik olarak ekle.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Bu hata ayıklama oturumu sonlandırıldığında durdurulacak hata ayıklama oturumlarının listesi.","items":{"type":"string","uniqueItems":true},"type":"array"},"console":{"default":"internalConsole","description":"Hata ayıklama hedefinin başlatılacağı yer.","enum":["internalConsole","integratedTerminal","externalTerminal"],"enumDescriptions":["VS Code Hata Ayıklama Konsolu (bir programdan giriş okumayı desteklemez)","VS Code'un tümleşik terminali","Dış terminal kullanıcı ayarları aracılığıyla yapılandırılabilir"],"type":"string"},"customDescriptionGenerator":{"description":"Hata ayıklayıcısının nesneler (yerel değişkenler vb.) için gösterdiği metinsel açıklamayı özelleştirin. Örnekler:\r\n      1. this.toString () // tüm nesneleri yazdırmak için toString çağırır\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n      3. işlev (def) { return this.customDescription ? this.customDescription() : def } // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n     ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Hata ayıklamada bir nesne için gösterilen özellikleri özelleştirin (yerel değişkenler, vb...). Örnekler:\r\n    1. { ...this, extraProperty: '12345' } // Tüm nesnelere extraProperty 12345 ekleyin\r\n    2. this.customProperties ? this.customProperties() : this // Varsa customProperties yöntemini kullanın, yoksa buradaki özellikleri kullanın (varsayılan özellikler)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Varsa customDescription yöntemini kullanın, yoksa varsayılan özellikleri döndürün\r\n\r\n    Kullanım dışı: Bu, burada açıklanan şekilde uygulanana kadar bu özelliğin geçici bir uygulamasıdır: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Hataları ayıklanan programa ait çalışma dizininin mutlak yolu. localRoot ayarladıysanız cwd bu değerle eşleşir. Aksi takdirde, workspaceFolder klasörünüze geri döner","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Diskteki dosyaların içeriklerinin çalışma zamanında yüklenenlerle eşleşip eşleşmediğini doğrulayıp doğrulamadığımızı belirtir. Bu, çeşitli senaryolarda kullanışlıdır ve bazılarında gereklidir ancak örneğin, betiklerin sunucu tarafında dönüşümüne sahipseniz sorunlara neden olabilir.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Hata ayıklayıcının, kaynak kullanımı yoğun olan WebAssembly'den DWARF hata ayıklama sembollerini okumayı deneyip denemeyeceğini değiştirir. İşlev için 'ms-vscode.wasm-debugging' uzantısını gerektirir.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Programa geçirilen ortam değişkenleri. `null` değeri, değişkeni ortamdan kaldırır.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Ortam değişkeni tanımlarını içeren bir dosyanın mutlak yolu.","type":"string"},"experimentalNetworking":{"default":"auto","description":"Node.js'de deneysel incelemeyi etkinleştirin. 'Otomatik' olarak ayarlandığında bu, destekleyen Node.js sürümleri için etkinleştirilir. Açıkça etkinleştirmek veya devre dışı bırakmak için 'açık' veya 'kapalı' olarak ayarlanmalıdır.","enum":["auto","on","off"],"type":"string"},"killBehavior":{"default":"forceful","enum":["forceful","polite","none"],"markdownDescription":"Oturum durdurulurken hata ayıklama işlemlerinin nasıl sonlandırılacağını yapılandırır. Şunlardan biri olabilir:\r\n\r\n- zorla (varsayılan): işlem ağacını zorla sonlandırır. Posix üzerinde SIGKILL veya Windows'da `taskkill.exe /F` gönderir.\r\n- zorlama: işlem ağacını dikkatlice kapatır. Yanlış davranan işlemlerin bu şekilde kapatıldıktan sonra çalışmaya devam etmesi olasıdır. Posix üzerinde SIGTERM gönderir veya Windows üzerinde `/F` (zorla) bayrağı olmadan `taskkill.exe` gönderir.\r\n- yok: sonlandırma gerçekleşmez.","type":"string"},"localRoot":{"default":null,"description":"Programı içeren yerel dizinin yolu.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Otomatik sürüm algılamasının çalışmadığı durumlarda belirli davranışları devre dışı bırakmak veya etkinleştirmek için kullanılabilen ve şu an çalışmakta olan düğüm sürümünü açık olarak belirtmenize olanak tanır.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Kaynak eşlemeleri etkinse bu glob desenleri, oluşturulan JavaScript dosyalarını belirtir. Bir desen `!` ile başlarsa dosyalar hariç tutulur. Belirtilmezse, oluşturulan kodun, kaynağıyla aynı dizinde olması beklenir.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Çıkış iletilerinin yakalanacağı konum: `Konsol` olarak ayarlanırsa varsayılan hata ayıklama API'si veya `std `olarak ayarlanırsa stdout/stderr akışları."},"pauseForSourceMap":{"default":false,"markdownDescription":"Whether to wait for source maps to load for each incoming script. This has a performance overhead, and might be safely disabled when running off of disk, so long as `rootPath` is not disabled.","type":"boolean"},"profileStartup":{"default":true,"description":"True ise, işlem başlatıldıktan hemen sonra profil oluşturulmaya başlanır","type":"boolean"},"program":{"default":"","description":"Programın mutlak yolu. Oluşturulan değer package.json dosyasına ve açılmış dosyalara bakılarak tahmin edilir. Bu özniteliği düzenleyin.","tags":["setup"],"type":"string"},"remoteRoot":{"default":null,"description":"Programı içeren uzak dizinin mutlak yolu.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"A list of minimatch patterns for locations (folders and URLs) in which source maps can be used to resolve local files. This can be used to avoid incorrectly breaking in external source mapped code. Patterns can be prefixed with \"!\" to exclude them. May be set to an empty array or null to avoid restriction.","items":{"type":"string"},"type":["array","null"]},"restart":{"default":true,"description":"Bağlantı kesilirse programa yeniden bağlanmayı deneyin. `True` olarak ayarlanırsa, süresiz olarak her saniye deneyeceğiz. Bunun yerine nesnede `delay` ve `maxAttempts` belirterek aralığı ve maksimum deneme sayısını özelleştirebilirsiniz.","oneOf":[{"type":"boolean"},{"properties":{"delay":{"default":1000,"minimum":0,"type":"number"},"maxAttempts":{"default":10,"minimum":0,"type":"number"}},"type":"object"}]},"runtimeArgs":{"default":[],"description":"Çalışma zamanı yürütülebilir dosyasına geçirilen isteğe bağlı bağımsız değişkenler.","items":{"type":"string"},"tags":["setup"],"type":"array"},"runtimeExecutable":{"default":"node","markdownDescription":"Kullanılacak çalıştırma zamanı. Mutlak bir yol veya PATH üzerinde bulunan bir çalıştırma zamanının adı. Atlanırsa `node` varsayılır.","type":["string","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Giriş noktası kesme noktalarının el ile ekleneceği desenlerin listesi. Bu, hata ayıklayıcıya mevcut olmayan veya başlatmadan önce algılanamayan kaynak eşlemelerini [Sunucusuz çerçeve ile](https://github.com/microsoft/vscode-js-debug/issues/492) kullanırken kesme noktalarını ayarlama fırsatı vermek için yararlı olabilir.","type":"array"},"runtimeVersion":{"default":"default","markdownDescription":"Kullanılacak `node` çalışma zamanı sürümü. `nvm` gerektirir.","type":"string"},"showAsyncStacks":{"default":true,"description":"Geçerli çağrı yığınına yol açan asenkron çağrıları gösterin.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Hata ayıklama sırasında atlanması Hata ayıklama sırasında atlanacak bir dizi dosya veya klasör adı veya yol glob'u. Yıldız kalıplarına ve olumsuzlamalara izin verilir, örneğin, `[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]`için dosya veya klasör adları veya yol globları dizisi. Yıldız desenlerine ve olumsuzluklara izin verilir; örneğin, '[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]'","type":"array"},"smartStep":{"default":true,"description":"Özgün kaynağa geri eşlenemeyen durumdaki oluşturulan kodu otomatik olarak adımlayın.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Kaynak dosyalarını, kaynak eşlemesinde belirtilen konumlardan dosyaların diskteki konumlarına yeniden yazmak için eşleme kümesi.","type":"object"},"sourceMapRenames":{"default":true,"description":"Kaynak eşlemelerinde \"names\" eşlemesinin kullanılıp kullanılmayacağı. Bu, kaynak içerik istemeyi gerektirir ve bazı hata ayıklayıcılarıyla yavaş çalışabilir.","type":"boolean"},"sourceMaps":{"default":true,"description":"(Varsa) JavaScript kaynak eşlemelerini kullanın.","type":"boolean"},"stopOnEntry":{"default":true,"description":"Başlatıldıktan sonra programı otomatik olarak durdurun.","type":["boolean","string"]},"timeout":{"default":10000,"description":"Node.js'ye bağlanmak için bu kadar milisaniye boyunca yeniden dene. Varsayılan: 10.000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","markdownDescription":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","properties":{"hoverEvaluation":{"default":500,"description":"Üzerine gelinen sembollerin değerinin değerlendirilmesine kadar geçen süre kesintiye uğradı. 0 olarak ayarlanırsa, üzerine gelme değerlendirmesi asla zaman aşımına uğramaz.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Minimum süre (sourceMapMinPause) dolduktan sonra kaynak eşlemelerinin işlenmesini beklerken harcanacak oturum başına izin verilen ek süre (milisaniye cinsinden)","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Betik ayrıştırıldığında her kaynak eşlemesinin işlenmesi için harcanan minimum süre (milisaniye cinsinden)","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Configures what diagnostic output is produced.","oneOf":[{"description":"Trace may be set to 'true' to write diagnostic logs to the disk.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Configures where on disk logs are written.","type":["string","null"]},"stdio":{"description":"Whether to return trace data from the launched application or browser.","type":"boolean"}},"type":"object"}]}},"type":"object"},{"additionalProperties":false,"default":{"program":"npm start"},"description":"JavaScript Hata Ayıklama Terminali","properties":{"autoAttachChildProcesses":{"default":true,"description":"Hata ayıklayıcıyı yeni alt işlemlere otomatik olarak ekle.","type":"boolean"},"cascadeTerminateToConfigurations":{"default":[],"description":"Bu hata ayıklama oturumu sonlandırıldığında durdurulacak hata ayıklama oturumlarının listesi.","items":{"type":"string","uniqueItems":true},"type":"array"},"command":{"default":"npm start","description":"Command to run in the launched terminal. If not provided, the terminal will open without launching a program.","tags":["setup"],"type":["string","null"]},"customDescriptionGenerator":{"description":"Hata ayıklayıcısının nesneler (yerel değişkenler vb.) için gösterdiği metinsel açıklamayı özelleştirin. Örnekler:\r\n      1. this.toString () // tüm nesneleri yazdırmak için toString çağırır\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n      3. işlev (def) { return this.customDescription ? this.customDescription() : def } // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n     ","type":"string"},"customPropertiesGenerator":{"deprecated":true,"description":"Hata ayıklamada bir nesne için gösterilen özellikleri özelleştirin (yerel değişkenler, vb...). Örnekler:\r\n    1. { ...this, extraProperty: '12345' } // Tüm nesnelere extraProperty 12345 ekleyin\r\n    2. this.customProperties ? this.customProperties() : this // Varsa customProperties yöntemini kullanın, yoksa buradaki özellikleri kullanın (varsayılan özellikler)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Varsa customDescription yöntemini kullanın, yoksa varsayılan özellikleri döndürün\r\n\r\n    Kullanım dışı: Bu, burada açıklanan şekilde uygulanana kadar bu özelliğin geçici bir uygulamasıdır: https://github.com/microsoft/vscode/issues/102181","type":"string"},"cwd":{"default":"${workspaceFolder}","description":"Hataları ayıklanan programa ait çalışma dizininin mutlak yolu. localRoot ayarladıysanız cwd bu değerle eşleşir. Aksi takdirde, workspaceFolder klasörünüze geri döner","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"],"type":"string"},"enableContentValidation":{"default":true,"description":"Diskteki dosyaların içeriklerinin çalışma zamanında yüklenenlerle eşleşip eşleşmediğini doğrulayıp doğrulamadığımızı belirtir. Bu, çeşitli senaryolarda kullanışlıdır ve bazılarında gereklidir ancak örneğin, betiklerin sunucu tarafında dönüşümüne sahipseniz sorunlara neden olabilir.","type":"boolean"},"enableDWARF":{"default":true,"markdownDescription":"Hata ayıklayıcının, kaynak kullanımı yoğun olan WebAssembly'den DWARF hata ayıklama sembollerini okumayı deneyip denemeyeceğini değiştirir. İşlev için 'ms-vscode.wasm-debugging' uzantısını gerektirir.","type":"boolean"},"env":{"additionalProperties":{"type":["string","null"]},"default":{},"markdownDescription":"Programa geçirilen ortam değişkenleri. `null` değeri, değişkeni ortamdan kaldırır.","tags":["setup"],"type":"object"},"envFile":{"default":"${workspaceFolder}/.env","description":"Ortam değişkeni tanımlarını içeren bir dosyanın mutlak yolu.","type":"string"},"localRoot":{"default":null,"description":"Programı içeren yerel dizinin yolu.","type":["string","null"]},"nodeVersionHint":{"default":12,"description":"Otomatik sürüm algılamasının çalışmadığı durumlarda belirli davranışları devre dışı bırakmak veya etkinleştirmek için kullanılabilen ve şu an çalışmakta olan düğüm sürümünü açık olarak belirtmenize olanak tanır.","minimum":8,"type":"number"},"outFiles":{"default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"description":"Kaynak eşlemeleri etkinse bu glob desenleri, oluşturulan JavaScript dosyalarını belirtir. Bir desen `!` ile başlarsa dosyalar hariç tutulur. Belirtilmezse, oluşturulan kodun, kaynağıyla aynı dizinde olması beklenir.","items":{"type":"string"},"tags":["setup"],"type":["array"]},"outputCapture":{"default":"console","enum":["console","std"],"markdownDescription":"Çıkış iletilerinin yakalanacağı konum: `Konsol` olarak ayarlanırsa varsayılan hata ayıklama API'si veya `std `olarak ayarlanırsa stdout/stderr akışları."},"pauseForSourceMap":{"default":false,"markdownDescription":"Whether to wait for source maps to load for each incoming script. This has a performance overhead, and might be safely disabled when running off of disk, so long as `rootPath` is not disabled.","type":"boolean"},"remoteRoot":{"default":null,"description":"Programı içeren uzak dizinin mutlak yolu.","type":["string","null"]},"resolveSourceMapLocations":{"default":["${workspaceFolder}/**","!**/node_modules/**"],"description":"A list of minimatch patterns for locations (folders and URLs) in which source maps can be used to resolve local files. This can be used to avoid incorrectly breaking in external source mapped code. Patterns can be prefixed with \"!\" to exclude them. May be set to an empty array or null to avoid restriction.","items":{"type":"string"},"type":["array","null"]},"runtimeSourcemapPausePatterns":{"default":[],"items":{"type":"string"},"markdownDescription":"Giriş noktası kesme noktalarının el ile ekleneceği desenlerin listesi. Bu, hata ayıklayıcıya mevcut olmayan veya başlatmadan önce algılanamayan kaynak eşlemelerini [Sunucusuz çerçeve ile](https://github.com/microsoft/vscode-js-debug/issues/492) kullanırken kesme noktalarını ayarlama fırsatı vermek için yararlı olabilir.","type":"array"},"showAsyncStacks":{"default":true,"description":"Geçerli çağrı yığınına yol açan asenkron çağrıları gösterin.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Hata ayıklama sırasında atlanması Hata ayıklama sırasında atlanacak bir dizi dosya veya klasör adı veya yol glob'u. Yıldız kalıplarına ve olumsuzlamalara izin verilir, örneğin, `[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]`için dosya veya klasör adları veya yol globları dizisi. Yıldız desenlerine ve olumsuzluklara izin verilir; örneğin, '[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]'","type":"array"},"smartStep":{"default":true,"description":"Özgün kaynağa geri eşlenemeyen durumdaki oluşturulan kodu otomatik olarak adımlayın.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Kaynak dosyalarını, kaynak eşlemesinde belirtilen konumlardan dosyaların diskteki konumlarına yeniden yazmak için eşleme kümesi.","type":"object"},"sourceMapRenames":{"default":true,"description":"Kaynak eşlemelerinde \"names\" eşlemesinin kullanılıp kullanılmayacağı. Bu, kaynak içerik istemeyi gerektirir ve bazı hata ayıklayıcılarıyla yavaş çalışabilir.","type":"boolean"},"sourceMaps":{"default":true,"description":"(Varsa) JavaScript kaynak eşlemelerini kullanın.","type":"boolean"},"timeout":{"default":10000,"description":"Node.js'ye bağlanmak için bu kadar milisaniye boyunca yeniden dene. Varsayılan: 10.000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","markdownDescription":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","properties":{"hoverEvaluation":{"default":500,"description":"Üzerine gelinen sembollerin değerinin değerlendirilmesine kadar geçen süre kesintiye uğradı. 0 olarak ayarlanırsa, üzerine gelme değerlendirmesi asla zaman aşımına uğramaz.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Minimum süre (sourceMapMinPause) dolduktan sonra kaynak eşlemelerinin işlenmesini beklerken harcanacak oturum başına izin verilen ek süre (milisaniye cinsinden)","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Betik ayrıştırıldığında her kaynak eşlemesinin işlenmesi için harcanan minimum süre (milisaniye cinsinden)","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Configures what diagnostic output is produced.","oneOf":[{"description":"Trace may be set to 'true' to write diagnostic logs to the disk.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Configures where on disk logs are written.","type":["string","null"]},"stdio":{"description":"Whether to return trace data from the launched application or browser.","type":"boolean"}},"type":"object"}]}},"type":"object"}]},"showAsyncStacks":{"default":true,"description":"Geçerli çağrı yığınına yol açan asenkron çağrıları gösterin.","oneOf":[{"type":"boolean"},{"properties":{"onAttach":{"default":32,"type":"number"}},"required":["onAttach"],"type":"object"},{"properties":{"onceBreakpointResolved":{"default":32,"type":"number"}},"required":["onceBreakpointResolved"],"type":"object"}]},"skipFiles":{"default":["${/**"],"description":"Hata ayıklama sırasında atlanması Hata ayıklama sırasında atlanacak bir dizi dosya veya klasör adı veya yol glob'u. Yıldız kalıplarına ve olumsuzlamalara izin verilir, örneğin, `[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]`için dosya veya klasör adları veya yol globları dizisi. Yıldız desenlerine ve olumsuzluklara izin verilir; örneğin, '[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]'","type":"array"},"smartStep":{"default":true,"description":"Özgün kaynağa geri eşlenemeyen durumdaki oluşturulan kodu otomatik olarak adımlayın.","type":"boolean"},"sourceMapPathOverrides":{"default":{"meteor://💻app/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","webpack://?:*/*":"${workspaceFolder}/*"},"description":"Kaynak dosyalarını, kaynak eşlemesinde belirtilen konumlardan dosyaların diskteki konumlarına yeniden yazmak için eşleme kümesi.","type":"object"},"sourceMapRenames":{"default":true,"description":"Kaynak eşlemelerinde \"names\" eşlemesinin kullanılıp kullanılmayacağı. Bu, kaynak içerik istemeyi gerektirir ve bazı hata ayıklayıcılarıyla yavaş çalışabilir.","type":"boolean"},"sourceMaps":{"default":true,"description":"(Varsa) JavaScript kaynak eşlemelerini kullanın.","type":"boolean"},"timeout":{"default":10000,"description":"Node.js'ye bağlanmak için bu kadar milisaniye boyunca yeniden dene. Varsayılan: 10.000 ms.","type":"number"},"timeouts":{"additionalProperties":false,"default":{},"description":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","markdownDescription":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","properties":{"hoverEvaluation":{"default":500,"description":"Üzerine gelinen sembollerin değerinin değerlendirilmesine kadar geçen süre kesintiye uğradı. 0 olarak ayarlanırsa, üzerine gelme değerlendirmesi asla zaman aşımına uğramaz.","type":"number"},"sourceMapCumulativePause":{"default":1000,"description":"Minimum süre (sourceMapMinPause) dolduktan sonra kaynak eşlemelerinin işlenmesini beklerken harcanacak oturum başına izin verilen ek süre (milisaniye cinsinden)","type":"number"},"sourceMapMinPause":{"default":1000,"description":"Betik ayrıştırıldığında her kaynak eşlemesinin işlenmesi için harcanan minimum süre (milisaniye cinsinden)","type":"number"}},"type":"object"},"trace":{"default":true,"description":"Configures what diagnostic output is produced.","oneOf":[{"description":"Trace may be set to 'true' to write diagnostic logs to the disk.","type":"boolean"},{"additionalProperties":false,"properties":{"logFile":{"description":"Configures where on disk logs are written.","type":["string","null"]},"stdio":{"description":"Whether to return trace data from the launched application or browser.","type":"boolean"}},"type":"object"}]},"url":{"default":"http://localhost:8080","description":"Tam olarak bu URL'ye sahip bir sekme arayacak ve bulunursa ona eklenecek","tags":["setup"],"type":"string"},"urlFilter":{"default":"","description":"Bu URL'yi içeren bir sayfa arar ve bulunursa sayfaya ekler. * joker karakterler içerebilir.","type":"string"},"useWebView":{"default":false,"description":"'True' olduğunda hata ayıklayıcı, çalışma zamanı yürütülebilir dosyasını WebView betik içeriğinde hata ayıklamanıza olanak tanıyan WebView içeren bir konak uygulama olarak değerlendirir.","type":"boolean"},"userDataDir":{"default":true,"description":"Varsayılan olarak tarayıcı, geçici klasöre ayrı bir kullanıcı profiliyle yüklenir. Bu ayarı geçersiz kılmak için bu seçeneği kullanın. Varsayılan kullanıcı profilinizle başlatmak için ayarı false olarak belirleyin. Bir örnek zaten \"userDataDir\" öğesinden çalışıyorsa yeni bir tarayıcı başlatılamaz.","type":["string","boolean"]},"vueComponentPaths":{"default":["${workspaceFolder}/**/*.vue"],"description":"`*.vue` bileşenlerini bulmaya yönelik dosya glob desenlerinin listesi. Varsayılan olarak, tüm çalışma alanını arar. Vue'nun kaynak eşlemelerinin Vue CLI 4'te gerektirdiği ek aramalar nedeniyle bunun belirtilmesi gerekir. Bunu boş bir diziye ayarlayarak bu özel işlemeyi devre dışı bırakabilirsiniz.","type":"array"},"webRoot":{"default":"${workspaceFolder}","description":"Bu, web sunucusu kökü için çalışma alanı mutlak yolunu belirtir. `/app.js` gibi yolları diskte dosyalara çözümlemek için kullanılır. \"/\" için pathMapping öğesine yönelik kısaltma","tags":["setup"],"type":"string"}}}},"configurationSnippets":[{"body":{"name":"Launch Edge","request":"launch","type":"msedge","url":"http://localhost:8080","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Launch Edge to debug a URL","label":"Edge: Başlat"},{"body":{"name":"Attach to Edge","port":9222,"request":"attach","type":"msedge","webRoot":"^\"${2:\\${workspaceFolder\\}}\""},"description":"Attach to an instance of Edge already in debug mode","label":"Edge: Ekle"}],"label":"Web Uygulaması (Edge)","strings":{"unverifiedBreakpoints":"Kesme noktalarınızın bazıları ayarlanamadı. Bir sorun yaşıyorsanız, [başlatma yapılandırmanızda sorun gidermek](command:extension.js-debug.createDiagnostics) için komutunu kullanın."},"type":"msedge"}],"commands":[{"command":"extension.js-debug.prettyPrint","title":"Pretty print for debugging","category":"Debug","icon":"$(json)"},{"command":"extension.js-debug.toggleSkippingFile","title":{"value":"Bu Dosyayı Atlamayı Aç/Kapat","original":"Toggle Skipping this File"},"category":"Debug"},{"command":"extension.js-debug.addCustomBreakpoints","title":{"value":"Olay Dinleyicisi Kesme Noktasını Aç/Kapat","original":"Toggle Event Listener Breakpoints"},"icon":"$(add)"},{"command":"extension.js-debug.removeAllCustomBreakpoints","title":{"value":"Tüm Olay Dinleyicisi Kesme Noktalarını Kaldır","original":"Remove All Event Listener Breakpoints"},"icon":"$(close-all)"},{"command":"extension.js-debug.addXHRBreakpoints","title":{"value":"XHR’yi Ekle/Kesme Noktasını Getir","original":"Add XHR/fetch Breakpoint"},"icon":"$(add)"},{"command":"extension.js-debug.removeXHRBreakpoint","title":{"value":"XHR’yi Kaldır/Kesme Noktasını Getir","original":"Remove XHR/fetch Breakpoint"},"icon":"$(remove)"},{"command":"extension.js-debug.editXHRBreakpoints","title":{"value":"XHR’yi Düzenle/Kesme Noktasını Getir","original":"Edit XHR/fetch Breakpoint"},"icon":"$(edit)"},{"command":"extension.pwa-node-debug.attachNodeProcess","title":{"value":"Düğüm İşlemine Ekle","original":"Attach to Node Process"},"category":"Debug"},{"command":"extension.js-debug.npmScript","title":{"value":"npm Betiğinin Hatalarını Ayıkla","original":"Debug npm Script"},"category":"Debug"},{"command":"extension.js-debug.createDebuggerTerminal","title":{"value":"JavaScript Hata Ayıklama Terminali","original":"JavaScript Debug Terminal"},"category":"Debug"},{"command":"extension.js-debug.startProfile","title":{"value":"Performans Profilini Al","original":"Take Performance Profile"},"category":"Debug","icon":"$(record)"},{"command":"extension.js-debug.stopProfile","title":{"value":"Performans Profilini Durdur","original":"Stop Performance Profile"},"category":"Debug","icon":"resources/dark/stop-profiling.svg"},{"command":"extension.js-debug.revealPage","title":{"value":"Odak Sekmesi","original":"Focus Tab"},"category":"Debug"},{"command":"extension.js-debug.debugLink","title":{"value":"Bağlantıyı Aç","original":"Open Link"},"category":"Debug"},{"command":"extension.js-debug.createDiagnostics","title":{"value":"Kesme Noktası Sorunlarını Tanıla","original":"Diagnose Breakpoint Problems"},"category":"Debug"},{"command":"extension.js-debug.getDiagnosticLogs","title":{"value":"JS Hata Ayıklama Tanılama Günlüklerini Kaydet","original":"Save Diagnostic JS Debug Logs"},"category":"Debug"},{"command":"extension.node-debug.startWithStopOnEntry","title":{"value":"Hata Ayıklamaya Başla ve Girişte Dur","original":"Start Debugging and Stop on Entry"},"category":"Debug"},{"command":"extension.js-debug.openEdgeDevTools","title":{"value":"Tarayıcı Devtools'u aç","original":"Open Browser Devtools"},"icon":"$(inspect)","category":"Debug"},{"command":"extension.js-debug.callers.add","title":{"value":"Çağıranı Dışla","original":"Exclude Caller"},"category":"Debug"},{"command":"extension.js-debug.callers.remove","title":{"value":"Dışlanan çağıranı kaldır","original":"Remove excluded caller"},"icon":"$(close)"},{"command":"extension.js-debug.callers.removeAll","title":{"value":"Dışlanan tüm çağıranları kaldır","original":"Remove all excluded callers"},"icon":"$(clear-all)"},{"command":"extension.js-debug.callers.goToCaller","title":{"value":"Çağıran konumuna git","original":"Go to caller location"},"icon":"$(call-outgoing)"},{"command":"extension.js-debug.callers.gotToTarget","title":{"value":"Hedef konuma git","original":"Go to target location"},"icon":"$(call-incoming)"},{"command":"extension.js-debug.enableSourceMapStepping","title":{"value":"Kaynak Eşlenmiş Adımlama'yı Etkinleştir","original":"Enable Source Mapped Stepping"},"icon":"$(compass-dot)"},{"command":"extension.js-debug.disableSourceMapStepping","title":{"value":"Kaynak Eşlenmiş Adımlama'yı Kapat","original":"Disable Source Mapped Stepping"},"icon":"$(compass)"},{"command":"extension.js-debug.network.viewRequest","title":{"value":"İsteği cURL olarak görüntüle","original":"View Request as cURL"},"icon":"$(arrow-right)"},{"command":"extension.js-debug.network.clear","title":{"value":"Ağ Günlüğünü Temizle","original":"Clear Network Log"},"icon":"$(clear-all)"},{"command":"extension.js-debug.network.openBody","title":{"value":"Yanıt Gövdesini Aç","original":"Open Response Body"}},{"command":"extension.js-debug.network.openBodyInHex","title":{"value":"Yanıt Gövdesini Onaltılık Düzenleyicide Aç","original":"Open Response Body in Hex Editor"}},{"command":"extension.js-debug.network.replayXHR","title":{"value":"İsteği Yeniden Oynat","original":"Replay Request"}},{"command":"extension.js-debug.network.copyUri","title":{"value":"İstek URL’sini kopyala","original":"Copy Request URL"}}],"keybindings":[{"command":"extension.node-debug.startWithStopOnEntry","key":"F10","mac":"F10","when":"debugConfigurationType == pwa-node && !inDebugMode || debugConfigurationType == pwa-extensionHost && !inDebugMode || debugConfigurationType == node && !inDebugMode"},{"command":"extension.node-debug.startWithStopOnEntry","key":"F11","mac":"F11","when":"debugConfigurationType == pwa-node && !inDebugMode && activeViewlet == workbench.view.debug || debugConfigurationType == pwa-extensionHost && !inDebugMode && activeViewlet == workbench.view.debug || debugConfigurationType == node && !inDebugMode && activeViewlet == workbench.view.debug"}],"configuration":{"title":"JavaScript Debugger","properties":{"debug.javascript.codelens.npmScripts":{"enum":["top","all","never"],"default":"top","description":"“Çalıştırma” ve “Hata Ayıklama” CodeLens’in NPM betiklerinizde gösterilmesi gereken yer. “Tümünde”, betiklerde, betik bölümünün “üstünde” veya “hiçbir zaman” olabilir."},"debug.javascript.terminalOptions":{"type":"object","description":"Default launch options for the JavaScript debug terminal and npm scripts.","default":{},"properties":{"resolveSourceMapLocations":{"type":["array","null"],"description":"A list of minimatch patterns for locations (folders and URLs) in which source maps can be used to resolve local files. This can be used to avoid incorrectly breaking in external source mapped code. Patterns can be prefixed with \"!\" to exclude them. May be set to an empty array or null to avoid restriction.","default":["${workspaceFolder}/**","!**/node_modules/**"],"items":{"type":"string"}},"outFiles":{"type":["array"],"description":"Kaynak eşlemeleri etkinse bu glob desenleri, oluşturulan JavaScript dosyalarını belirtir. Bir desen `!` ile başlarsa dosyalar hariç tutulur. Belirtilmezse, oluşturulan kodun, kaynağıyla aynı dizinde olması beklenir.","default":["${workspaceFolder}/**/*.(m|c|)js","!**/node_modules/**"],"items":{"type":"string"},"tags":["setup"]},"pauseForSourceMap":{"type":"boolean","markdownDescription":"Whether to wait for source maps to load for each incoming script. This has a performance overhead, and might be safely disabled when running off of disk, so long as `rootPath` is not disabled.","default":false},"showAsyncStacks":{"description":"Geçerli çağrı yığınına yol açan asenkron çağrıları gösterin.","default":true,"oneOf":[{"type":"boolean"},{"type":"object","required":["onAttach"],"properties":{"onAttach":{"type":"number","default":32}}},{"type":"object","required":["onceBreakpointResolved"],"properties":{"onceBreakpointResolved":{"type":"number","default":32}}}]},"skipFiles":{"type":"array","description":"Hata ayıklama sırasında atlanması Hata ayıklama sırasında atlanacak bir dizi dosya veya klasör adı veya yol glob'u. Yıldız kalıplarına ve olumsuzlamalara izin verilir, örneğin, `[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]`için dosya veya klasör adları veya yol globları dizisi. Yıldız desenlerine ve olumsuzluklara izin verilir; örneğin, '[\"**/node_modules/**\", \"!**/node_modules/my-module/**\"]'","default":["${/**"]},"smartStep":{"type":"boolean","description":"Özgün kaynağa geri eşlenemeyen durumdaki oluşturulan kodu otomatik olarak adımlayın.","default":true},"sourceMaps":{"type":"boolean","description":"(Varsa) JavaScript kaynak eşlemelerini kullanın.","default":true},"sourceMapRenames":{"type":"boolean","default":true,"description":"Kaynak eşlemelerinde \"names\" eşlemesinin kullanılıp kullanılmayacağı. Bu, kaynak içerik istemeyi gerektirir ve bazı hata ayıklayıcılarıyla yavaş çalışabilir."},"sourceMapPathOverrides":{"type":"object","description":"Kaynak dosyalarını, kaynak eşlemesinde belirtilen konumlardan dosyaların diskteki konumlarına yeniden yazmak için eşleme kümesi.","default":{"webpack://?:*/*":"${workspaceFolder}/*","webpack:///./~/*":"${workspaceFolder}/node_modules/*","meteor://💻app/*":"${workspaceFolder}/*"}},"timeout":{"type":"number","description":"Node.js'ye bağlanmak için bu kadar milisaniye boyunca yeniden dene. Varsayılan: 10.000 ms.","default":10000},"timeouts":{"type":"object","description":"Birkaç hata ayıklayıcı işlemi için zaman aşımları.","default":{},"properties":{"sourceMapMinPause":{"type":"number","description":"Betik ayrıştırıldığında her kaynak eşlemesinin işlenmesi için harcanan minimum süre (milisaniye cinsinden)","default":1000},"sourceMapCumulativePause":{"type":"number","description":"Minimum süre (sourceMapMinPause) dolduktan sonra kaynak eşlemelerinin işlenmesini beklerken harcanacak oturum başına izin verilen ek süre (milisaniye cinsinden)","default":1000},"hoverEvaluation":{"type":"number","description":"Üzerine gelinen sembollerin değerinin değerlendirilmesine kadar geçen süre kesintiye uğradı. 0 olarak ayarlanırsa, üzerine gelme değerlendirmesi asla zaman aşımına uğramaz.","default":500}},"additionalProperties":false,"markdownDescription":"Birkaç hata ayıklayıcı işlemi için zaman aşımları."},"trace":{"description":"Configures what diagnostic output is produced.","default":true,"oneOf":[{"type":"boolean","description":"Trace may be set to 'true' to write diagnostic logs to the disk."},{"type":"object","additionalProperties":false,"properties":{"stdio":{"type":"boolean","description":"Whether to return trace data from the launched application or browser."},"logFile":{"type":["string","null"],"description":"Configures where on disk logs are written."}}}]},"outputCapture":{"enum":["console","std"],"markdownDescription":"Çıkış iletilerinin yakalanacağı konum: `Konsol` olarak ayarlanırsa varsayılan hata ayıklama API'si veya `std `olarak ayarlanırsa stdout/stderr akışları.","default":"console"},"enableContentValidation":{"default":true,"type":"boolean","description":"Diskteki dosyaların içeriklerinin çalışma zamanında yüklenenlerle eşleşip eşleşmediğini doğrulayıp doğrulamadığımızı belirtir. Bu, çeşitli senaryolarda kullanışlıdır ve bazılarında gereklidir ancak örneğin, betiklerin sunucu tarafında dönüşümüne sahipseniz sorunlara neden olabilir."},"customDescriptionGenerator":{"type":"string","description":"Hata ayıklayıcısının nesneler (yerel değişkenler vb.) için gösterdiği metinsel açıklamayı özelleştirin. Örnekler:\r\n      1. this.toString () // tüm nesneleri yazdırmak için toString çağırır\r\n      2. this.customDescription ? this.customDescription() : defaultValue // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n      3. işlev (def) { return this.customDescription ? this.customDescription() : def } // Varsa customDescription metodunu kullanın. Yoksa defaultValue döndürün\r\n     "},"customPropertiesGenerator":{"type":"string","deprecated":true,"description":"Hata ayıklamada bir nesne için gösterilen özellikleri özelleştirin (yerel değişkenler, vb...). Örnekler:\r\n    1. { ...this, extraProperty: '12345' } // Tüm nesnelere extraProperty 12345 ekleyin\r\n    2. this.customProperties ? this.customProperties() : this // Varsa customProperties yöntemini kullanın, yoksa buradaki özellikleri kullanın (varsayılan özellikler)\r\n    3. function () { return this.customProperties ? this.customProperties() : this } // Varsa customDescription yöntemini kullanın, yoksa varsayılan özellikleri döndürün\r\n\r\n    Kullanım dışı: Bu, burada açıklanan şekilde uygulanana kadar bu özelliğin geçici bir uygulamasıdır: https://github.com/microsoft/vscode/issues/102181"},"cascadeTerminateToConfigurations":{"type":"array","items":{"type":"string","uniqueItems":true},"default":[],"description":"Bu hata ayıklama oturumu sonlandırıldığında durdurulacak hata ayıklama oturumlarının listesi."},"enableDWARF":{"type":"boolean","default":true,"markdownDescription":"Hata ayıklayıcının, kaynak kullanımı yoğun olan WebAssembly'den DWARF hata ayıklama sembollerini okumayı deneyip denemeyeceğini değiştirir. İşlev için 'ms-vscode.wasm-debugging' uzantısını gerektirir."},"cwd":{"type":"string","description":"Hataları ayıklanan programa ait çalışma dizininin mutlak yolu. localRoot ayarladıysanız cwd bu değerle eşleşir. Aksi takdirde, workspaceFolder klasörünüze geri döner","default":"${workspaceFolder}","docDefault":"localRoot || ${workspaceFolder}","tags":["setup"]},"localRoot":{"type":["string",