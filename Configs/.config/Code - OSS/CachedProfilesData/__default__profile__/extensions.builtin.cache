stash","label":"Geçici kayıt"},{"id":"git.tags","label":"Etiketler"}],"configuration":{"title":"Git","properties":{"git.enabled":{"type":"boolean","scope":"resource","description":"Git'in etkinleştirilip etkinleştirilmediği.","default":true},"git.path":{"type":["string","null","array"],"markdownDescription":"Git yürütülebilir dosyasının yolu ve dosya adı, ör. `C:\\Program Files\\Git\\bin\\git.exe` (Windows).","default":null,"scope":"machine"},"git.autoRepositoryDetection":{"type":["boolean","string"],"enum":[true,false,"subFolders","openEditors"],"enumDescriptions":["Hem geçerli açık klasörün alt klasörlerini hem de açık dosyaların üst klasörlerini tarayın.","Otomatik depo taramasını devre dışı bırakın.","Şu anda açık olan klasörün alt klasörlerini tarayın.","Açık dosyaların üst klasörlerini tarayın."],"description":"Depoların otomatik olarak algılanması gereken zamanı yapılandırır.","default":true},"git.autorefresh":{"type":"boolean","description":"Otomatik yenilemenin etkinleştirilip etkinleştirilmediğini belirtir.","default":true},"git.autofetch":{"type":["boolean","string"],"enum":[true,false,"all"],"scope":"resource","markdownDescription":"True olarak ayarlandığında commit'ler geçerli Git deposunun varsayılan uzak deposundan otomatik olarak getirilir. `all` olarak ayarlandığında tüm uzak depolardan getirilir.","default":false,"tags":["usesOnlineServices"]},"git.autofetchPeriod":{"type":"number","scope":"resource","markdownDescription":"`#git.autofetch#` etkinleştirildiğinde her bir otomatik Git Fetch arasındaki süre (saniye cinsinden).","default":180},"git.defaultBranchName":{"type":"string","markdownDescription":"Yeni bir git deposu başlatılırken varsayılan dalın adı (ör. ana, ana hat, geliştirme). Boş olarak ayarlandığında, Git içinde yapılandırılan varsayılan dal adı kullanılır. **Not:** Git sürümü `2.28.0` veya üzerini gerektirir.","default":"main","scope":"resource"},"git.branchPrefix":{"type":"string","description":"Yeni dal oluşturulurken kullanılan ön ek.","default":"","scope":"resource"},"git.branchProtection":{"type":"array","markdownDescription":"Korumalı dalların listesi. Varsayılan olarak, değişiklikler korumalı bir dala kaydedilmeden önce bir istem gösterilir. İstem, `#git.branchProtectionPrompt#` ayarı kullanılarak denetlenebilir.","items":{"type":"string"},"default":[],"scope":"resource"},"git.branchProtectionPrompt":{"type":"string","description":"Değişiklikler korumalı bir dala kaydedilmeden önce bir istem olup olmadığını denetler.","enum":["alwaysCommit","alwaysCommitToNewBranch","alwaysPrompt"],"enumDescriptions":["Değişiklikleri her zaman korumalı dala kaydet.","Değişiklikleri her zaman yeni dala kaydet.","Değişiklikler korumalı bir dala kaydedilmeden önce her zaman sor."],"default":"alwaysPrompt","scope":"resource"},"git.branchValidationRegex":{"type":"string","description":"Yeni dal adlarını doğrulayacak normal ifade.","default":""},"git.branchWhitespaceChar":{"type":"string","description":"Yeni dal adlarındaki boşlukların yerine geçecek ve rastgele oluşturulmuş bir dal adının segmentlerini ayıracak karakter.","default":"-"},"git.branchRandomName.enable":{"type":"boolean","description":"Yeni bir dal oluşturulurken rastgele bir ad oluşturulup oluşturulmadığını denetler.","default":false,"scope":"resource"},"git.branchRandomName.dictionary":{"type":"array","markdownDescription":"Rastgele oluşturulan dal adı için kullanılan sözlüklerin listesi. Her değer, dal adının segmentini oluşturmak için kullanılan sözlüğü temsil eder. Desteklenen sözlükler: 'sıfatlar', 'hayvanlar', 'renkler' ve 'sayılar'.","items":{"type":"string","enum":["adjectives","animals","colors","numbers"],"enumDescriptions":["Rastgele bir sıfat","Rastgele bir hayvan adı","Rastgele bir renk adı","100 ve 999 arasında rastgele bir sayı"]},"minItems":1,"maxItems":5,"default":["adjectives","animals"],"scope":"resource"},"git.confirmSync":{"type":"boolean","description":"Git depolarını eşitlemeden önce onayla.","default":true},"git.countBadge":{"type":"string","enum":["all","tracked","off"],"enumDescriptions":["Tüm değişiklikleri say.","Yalnızca izlenen değişiklikleri say.","Sayacı kapatın."],"description":"Git sayısı rozetini denetler.","default":"all","scope":"resource"},"git.checkoutType":{"type":"array","items":{"type":"string","enum":["local","tags","remote"],"enumDescriptions":["Yerel dallar","Etiketler","Uzak dallar"]},"uniqueItems":true,"markdownDescription":"`Checkout to...` komutu çalıştırılırken hangi tür Git başvurularının listeleneceğini denetler.","default":["local","remote","tags"]},"git.ignoreLegacyWarning":{"type":"boolean","description":"Eski Git uyarısını yoksayar.","default":false},"git.ignoreMissingGitWarning":{"type":"boolean","description":"Git eksik olduğunda uyarıyı yoksayar.","default":false},"git.ignoreWindowsGit27Warning":{"type":"boolean","description":"Windows'a Git 2.25 - 2.26 yüklendiğinde uyarıyı yoksayar.","default":false},"git.ignoreLimitWarning":{"type":"boolean","description":"Depoda çok fazla değişiklik olduğunda uyarıyı yoksayar.","default":false},"git.ignoreRebaseWarning":{"type":"boolean","description":"Çekme sırasında dal yeniden temellendirilmiş gibi görünüyorsa uyarıyı yoksayar.","default":false},"git.defaultCloneDirectory":{"type":["string","null"],"default":null,"scope":"machine","description":"Git deposunun klonlanacağı varsayılan konum."},"git.useEditorAsCommitInput":{"type":"boolean","description":"İşleme giriş kutusunda herhangi bir ileti sağlanmamışsa, işleme iletilerini yazmak için tam metin düzenleyicisinin kullanılıp kullanılmayacağını kontrol eder.","default":true},"git.verboseCommit":{"type":"boolean","scope":"resource","markdownDescription":"`#git.useEditorAsCommitInput#` etkinleştirildiğinde ayrıntılı çıkışı etkinleştirin.","default":false},"git.enableSmartCommit":{"type":"boolean","scope":"resource","description":"Hazırlanmış değişiklik olmadığında tüm değişikliklere commit işlemi uygulayın.","default":false},"git.smartCommitChanges":{"type":"string","enum":["all","tracked"],"enumDescriptions":["Tüm değişiklikleri otomatik olarak hazırlayın.","Yalnızca izlenen değişiklikleri otomatik olarak hazırlayın."],"scope":"resource","description":"Hangi değişikliklerin Akıllı Commit tarafından otomatik olarak hazırlanacağını denetleyin.","default":"all"},"git.suggestSmartCommit":{"type":"boolean","scope":"resource","description":"Akıllı commit'in etkinleştirilmesini önerir. (Hazırlanmış değişiklik olmadığında tüm değişikliklere commit işlemi uygulayın.)","default":true},"git.enableCommitSigning":{"type":"boolean","scope":"resource","description":"GPG, X.509 veya SSH ile commit imzalamayı etkinleştirir.","default":false},"git.confirmEmptyCommits":{"type":"boolean","scope":"resource","description":"'Git: Commit Empty' komutu için her zaman boş commit'lerin oluşturulmasını onaylayın.","default":true},"git.decorations.enabled":{"type":"boolean","default":true,"description":"Git'in Gezgine ve Açık Düzenleyiciler görünümüne renk ve rozetlerle katkıda bulunup bulunmadığını denetler."},"git.enableStatusBarSync":{"type":"boolean","default":true,"description":"Git Sync komutunun durum çubuğunda görünüp görünmeyeceğini denetler.","scope":"resource"},"git.followTagsWhenSync":{"type":"boolean","scope":"resource","default":false,"description":"Eşitleme komutunu çalıştırırken tüm not eklenmiş etiketleri gönder."},"git.replaceTagsWhenPull":{"type":"boolean","scope":"resource","default":false,"description":"Çekme komutu çalıştırılırken çakışma olması durumunda yerel etiketleri uzak etiketlerle otomatik olarak değiştirin."},"git.promptToSaveFilesBeforeStash":{"type":"string","enum":["always","staged","never"],"enumDescriptions":["Tüm kaydedilmemiş dosyaları denetleyin.","Yalnızca kaydedilmemiş hazırlanmış dosyaları denetleyin.","Bu denetimi devre dışı bırakın."],"scope":"resource","default":"always","description":"Git'in değişiklikleri geçici olarak kaydetmeden önce kaydedilmemiş dosyaları kontrol etmesinin gerekip gerekmediğini denetler."},"git.promptToSaveFilesBeforeCommit":{"type":"string","enum":["always","staged","never"],"enumDescriptions":["Tüm kaydedilmemiş dosyaları denetleyin.","Yalnızca kaydedilmemiş hazırlanmış dosyaları denetleyin.","Bu denetimi devre dışı bırakın."],"scope":"resource","default":"always","description":"Git'in commit işlemi uygulamadan önce kaydedilmemiş dosyaları kontrol etmesinin gerekip gerekmediğini denetler."},"git.postCommitCommand":{"type":"string","enum":["none","push","sync"],"enumDescriptions":["Commit işleminden sonra herhangi bir komut çalıştırmayın.","İşleme başarılı olduktan sonra 'git push' komutunu çalıştırın.","İşleme başarılı olduktan sonra 'git pull' ve 'git push' komutunu çalıştırın."],"markdownDescription":"İşleme başarılı olduktan sonra bir git komutu çalıştırın.","scope":"resource","default":"none"},"git.rememberPostCommitCommand":{"type":"boolean","description":"İşlemeden sonra çalıştırılacak son git komutunu anımsayın.","scope":"resource","default":false},"git.openAfterClone":{"type":"string","enum":["always","alwaysNewWindow","whenNoFolderOpen","prompt"],"enumDescriptions":["Her zaman geçerli pencerede açın.","Her zaman yeni bir pencerede açın.","Yalnızca hiçbir klasör açık değilse geçerli pencerede aç.","Gerçekleştirilecek eylemi her zaman sorun."],"default":"prompt","description":"Klonlama sonrasında deponun otomatik olarak açılıp açılmayacağını denetler."},"git.showInlineOpenFileAction":{"type":"boolean","default":true,"description":"Git değişiklikleri görünümünde satır içi Dosya Aç eyleminin gösterilip gösterilmeyeceğini denetler."},"git.showPushSuccessNotification":{"type":"boolean","description":"Gönderim başarılı olduğunda bildirim gösterilip gösterilmeyeceğini denetler.","default":false},"git.inputValidation":{"type":"boolean","default":false,"description":"İşleme iletisi girişi doğrulama tanılamasının gösterilip gösterilmeyeceğini denetler."},"git.inputValidationLength":{"type":"number","default":72,"description":"Uyarının gösterilmesi için commit iletisi uzunluğu eşiğini denetler."},"git.inputValidationSubjectLength":{"type":["number","null"],"default":50,"markdownDescription":"Uyarının gösterilmesi için commit iletisi konu uzunluğu eşiğini denetler. `#git.inputValidationLength#` değerini devralmak için bu ayarı kaldırın."},"git.detectSubmodules":{"type":"boolean","scope":"resource","default":true,"description":"Git alt modüllerinin otomatik olarak algılanıp algılanmayacağını denetler."},"git.detectSubmodulesLimit":{"type":"number","scope":"resource","default":10,"description":"Saptanan Git alt modüllerinin sınırını denetler."},"git.alwaysShowStagedChangesResourceGroup":{"type":"boolean","scope":"resource","default":false,"description":"Hazırlanmış Değişiklikler kaynak grubunu her zaman görüntüleyin."},"git.alwaysSignOff":{"type":"boolean","scope":"resource","default":false,"description":"Tüm commit'ler için oturum kapatma bayrağını denetler."},"git.ignoreSubmodules":{"type":"boolean","scope":"resource","default":false,"description":"Dosya ağacındaki alt modüllerde yapılan değişiklikleri yoksayın."},"git.ignoredRepositories":{"type":"array","items":{"type":"string"},"default":[],"scope":"window","description":"Yok sayılacak Git depolarının listesi."},"git.scanRepositories":{"type":"array","items":{"type":"string"},"default":[],"scope":"resource","description":"Git depolarının aranacağı yolların listesi."},"git.showProgress":{"type":"boolean","description":"Git eylemlerinin ilerleme gösterip göstermeyeceğini denetler.","default":true,"scope":"resource"},"git.rebaseWhenSync":{"type":"boolean","scope":"resource","default":false,"description":"Yeniden eşitleme komutu çalıştırılırken Git'i yeniden temellendirmeyi kullanmaya zorla."},"git.pullBeforeCheckout":{"type":"boolean","scope":"resource","default":false,"description":"Giden işlemeleri olmayan bir dalın kullanıma alınmadan önce hızlı iletilip iletilmediğini kontrol eder."},"git.fetchOnPull":{"type":"boolean","scope":"resource","default":false,"description":"Etkin olduğunda, çekerken tüm dalları getirin. Aksi takdirde yalnızca geçerli dalı getirin."},"git.pruneOnFetch":{"type":"boolean","scope":"resource","default":false,"description":"Getirilirken ayıkla."},"git.pullTags":{"type":"boolean","scope":"resource","default":true,"description":"Çekerken tüm etiketleri getirin."},"git.autoStash":{"type":"boolean","scope":"resource","default":false,"description":"Değişiklikleri çekmeden önce hazırlayın ve başarılı çekmenin ardından geri yükleyin."},"git.allowForcePush":{"type":"boolean","default":false,"description":"Göndermeye zorla ayarının (kira ile veya kira olmadan) etkin olup olmadığını denetler."},"git.useForcePushWithLease":{"type":"boolean","default":true,"description":"Zorla gönderimin daha güvenli bir force-with-lease değişkeni kullanıp kullanmadığını denetler."},"git.useForcePushIfIncludes":{"type":"boolean","default":true,"markdownDescription":"Zorla gönderimin daha güvenli bir force-if-includes değişkeni kullanıp kullanmadığını denetler. Not: Bu ayar için '#git.useForcePushWithLease#' ayarının etkinleştirilmesi ve Git '2.30.0' veya üzeri sürümü gerekir."},"git.confirmForcePush":{"type":"boolean","default":true,"description":"Zorla gönderimden önce onay istenip istenmeyeceğini denetler."},"git.allowNoVerifyCommit":{"type":"boolean","default":false,"description":"Pre-commit ve commit-msg kancaları çalıştırılmadan commit işlemlerine izin verilip verilmediğini denetler."},"git.confirmNoVerifyCommit":{"type":"boolean","default":true,"description":"Doğrulama olmadan commit işlemi yapmadan önce onay istenip istenmeyeceğini denetler."},"git.closeDiffOnOperation":{"type":"boolean","scope":"resource","default":false,"description":"Değişiklikler geçici olarak kaydedildiğinde, işleme alındığında, atıldığında, hazırlandığında veya hazırlaması geri alındığında fark düzenleyicisinin otomatik olarak kapatılıp kapatılmayacağını denetler."},"git.openDiffOnClick":{"type":"boolean","scope":"resource","default":true,"description":"Değişikliğe tıklandığında fark düzenleyicisinin açılmasının gerekip gerekmediğini denetler. Aksi takdirde normal düzenleyici açılır."},"git.supportCancellation":{"type":"boolean","scope":"resource","default":false,"description":"Eşitleme eylemi çalıştırılırken kullanıcının işlemi iptal etme izni veren bir bildirimin görüntülenip görüntülenmeyeceğini denetler."},"git.branchSortOrder":{"type":"string","enum":["committerdate","alphabetically"],"default":"committerdate","description":"Dallar için sıralama düzenini denetler."},"git.untrackedChanges":{"type":"string","enum":["mixed","separate","hidden"],"enumDescriptions":["İzlenen ve izlenmeyen tüm değişiklikler birlikte görünür ve eşit davranış gösterir.","İzlenmeyen değişiklikler Kaynak Denetimi görünümünde ayrı olarak gösterilir. Ayrıca birkaç eylemden dışlanır.","İzlenmeyen değişiklikler gizlenir ve birkaç eylemden dışlanır."],"default":"mixed","description":"İzlenmeyen değişikliklerin nasıl davranacağını denetler.","scope":"resource"},"git.requireGitUserConfig":{"type":"boolean","description":"Açık Git kullanıcı yapılandırmasının gerekip gerekmediğini denetler veya yapılandırma eksikse Git'in tahminde bulunmasına olanak tanır.","default":true,"scope":"resource"},"git.showCommitInput":{"type":"boolean","scope":"resource","default":true,"description":"Git kaynağı denetim masasında commit girişinin gösterilip gösterilmeyeceğini denetler."},"git.terminalAuthentication":{"type":"boolean","default":true,"description":"VS Code'un Entegre Terminal'de oluşturulan Git işlemleri için kimlik doğrulama işleyicisi olup olmayacağını denetler. Not: Bu ayardaki bir değişikliği almak için terminallerin yeniden başlatılması gerekir."},"git.terminalGitEditor":{"type":"boolean","default":false,"description":"VS Code'un tümleşik terminalde oluşturulan Git işlemleri için Git düzenleyicisi olup olmayacağını denetler. Not: Bu ayardaki bir değişikliği almak için terminallerin yeniden başlatılması gerekir."},"git.useCommitInputAsStashMessage":{"type":"boolean","scope":"resource","default":false,"description":"Commit giriş kutusundan iletinin varsayılan geçici kayıt iletisi olarak kullanılıp kullanılmayacağını denetler."},"git.useIntegratedAskPass":{"type":"boolean","default":true,"description":"Tümleşik sürümü kullanmak için GIT_ASKPASS öğesinin üzerine yazılması gerekip gerekmediğini denetler."},"git.githubAuthentication":{"markdownDeprecationMessage":"This setting is now deprecated, please use `#github.gitAuthentication#` instead."},"git.timeline.date":{"type":"string","enum":["committed","authored"],"enumDescriptions":["Commit işlemi uygulanan tarihi kullan","Yazılan tarihi kullan"],"default":"committed","description":"Zaman Çizelgesi görünümünde öğeler için kullanılacak tarihi denetler.","scope":"window"},"git.timeline.showAuthor":{"type":"boolean","default":true,"description":"Commit yazarının Zaman Çizelgesi görünümünde gösterilip gösterilmeyeceğini denetler.","scope":"window"},"git.timeline.showUncommitted":{"type":"boolean","default":false,"description":"İşlenmemiş değişikliklerin Zaman Çizelgesi görünümünde gösterilip gösterilmeyeceğini denetler.","scope":"window"},"git.showActionButton":{"type":"object","additionalProperties":false,"description":"Eylem düğmesinin Kaynak Denetimi görünümünde gösterilip gösterilmediğini denetler.","properties":{"commit":{"type":"boolean","description":"Yerel dal, işlemeye hazır dosyaları değiştirdiğinde değişiklikleri işlemek için bir eylem düğmesi göster."},"publish":{"type":"boolean","description":"İzleme uzak dalı olmayan yerel dalı yayımlamak için bir eylem düğmesi göster."},"sync":{"type":"boolean","description":"Yerel dal, uzak dalın önünde veya arkasında olduğunda değişiklikleri eşitlemek için bir eylem düğmesi göster."}},"default":{"commit":true,"publish":true,"sync":true},"scope":"resource"},"git.statusLimit":{"type":"number","scope":"resource","default":10000,"description":"Git durum komutundan ayrıştırılabilecek değişiklik sayısının nasıl sınırlanacağını kontrol eder. Limitsiz olarak 0'a ayarlanabilir."},"git.repositoryScanIgnoredFolders":{"type":"array","items":{"type":"string"},"default":["node_modules"],"scope":"resource","markdownDescription":"\"#git.autoRepositoryDetection#\", \"true\" veya \"subFolders\" olarak ayarlandığında Git depoları taranırken yok sayılan klasörlerin listesi."},"git.repositoryScanMaxDepth":{"type":"number","scope":"resource","default":1,"markdownDescription":"`#git.autoRepositoryDetection#` değeri `true` veya '`subFolders` olarak ayarlandığında Git depoları için çalışma alanı klasörlerini tararken kullanılan derinliği kontrol eder. Sınır yok için `-1` olarak ayarlanamaz."},"git.commandsToLog":{"type":"array","items":{"type":"string"},"default":[],"markdownDescription":"`stdout` komutunun [git output](command:git.showOutput) oturumu açık olacak git komutlarının (ör. işleme, gönderme) listesi. Git komutunda yapılandırılmış bir istemci tarafı kancası varsa, istemci tarafı kancası `stdout` da [git output](command:git.showOutput) oturumunda açılır."},"git.mergeEditor":{"type":"boolean","default":false,"markdownDescription":"Şu anda çakışan dosyalar için birleştirme düzenleyicisini açın.","scope":"window"},"git.optimisticUpdate":{"type":"boolean","default":true,"markdownDescription":"Git komutlarını çalıştırdıktan sonra Kaynak Denetimi görünümünün durumunun iyimser bir şekilde güncelleştirilip güncelleştirilemediğini denetler.","scope":"resource","tags":["experimental"]},"git.openRepositoryInParentFolders":{"type":"string","enum":["always","never","prompt"],"enumDescriptions":["Her zaman bir depoyu çalışma alanlarının veya açık dosyaların üst klasörlerinde açın.","Hiç bir zaman bir depoyu çalışma alanlarının veya açık dosyaların üst klasörlerinde açma.","Çalışma alanlarının veya açık dosyaların üst klasörlerini, bir depoyu açmadan önce sor."],"default":"prompt","markdownDescription":"Çalışma alanının veya açık dosyaların üst klasörlerindeki bir deponun açılıp açılmayacağını denetleyin.","scope":"resource"},"git.similarityThreshold":{"type":"number","default":50,"minimum":0,"maximum":100,"markdownDescription":"Eklenen/silinen bir çift dosyada yeniden adlandırma sayılacak değişiklikler için benzerlik dizininin eşiğini (dosyanın boyutuna kıyasla ekleme/silme miktarı) denetler. **Not:** Git sürümü `2.18.0` veya üzerini gerektirir.","scope":"resource"}}},"colors":[{"id":"gitDecoration.addedResourceForeground","description":"Eklenen kaynakların rengi.","defaults":{"light":"#587c0c","dark":"#81b88b","highContrast":"#a1e3ad","highContrastLight":"#374e06"}},{"id":"gitDecoration.modifiedResourceForeground","description":"Değiştirilen kaynakların rengi.","defaults":{"light":"#895503","dark":"#E2C08D","highContrast":"#E2C08D","highContrastLight":"#895503"}},{"id":"gitDecoration.deletedResourceForeground","description":"Silinen kaynakların rengi.","defaults":{"light":"#ad0707","dark":"#c74e39","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.renamedResourceForeground","description":"Yeniden adlandırılan veya kopyalanan kaynakların rengi.","defaults":{"light":"#007100","dark":"#73C991","highContrast":"#73C991","highContrastLight":"#007100"}},{"id":"gitDecoration.untrackedResourceForeground","description":"İzlenmeyen kaynakların rengi.","defaults":{"light":"#007100","dark":"#73C991","highContrast":"#73C991","highContrastLight":"#007100"}},{"id":"gitDecoration.ignoredResourceForeground","description":"Yoksayılan kaynakların rengi.","defaults":{"light":"#8E8E90","dark":"#8C8C8C","highContrast":"#A7A8A9","highContrastLight":"#8e8e90"}},{"id":"gitDecoration.stageModifiedResourceForeground","description":"Hazırlanıp değiştirilen kaynakların rengi.","defaults":{"light":"#895503","dark":"#E2C08D","highContrast":"#E2C08D","highContrastLight":"#895503"}},{"id":"gitDecoration.stageDeletedResourceForeground","description":"Hazırlanıp silinen kaynakların rengi.","defaults":{"light":"#ad0707","dark":"#c74e39","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.conflictingResourceForeground","description":"Çakışmalara sahip kaynakların rengi.","defaults":{"light":"#ad0707","dark":"#e4676b","highContrast":"#c74e39","highContrastLight":"#ad0707"}},{"id":"gitDecoration.submoduleResourceForeground","description":"Alt modül kaynaklarının rengi.","defaults":{"light":"#1258a7","dark":"#8db9e2","highContrast":"#8db9e2","highContrastLight":"#1258a7"}}],"configurationDefaults":{"[git-commit]":{"editor.rulers":[50,72],"editor.wordWrap":"off","workbench.editor.restoreViewState":false},"[git-rebase]":{"workbench.editor.restoreViewState":false}},"viewsWelcome":[{"view":"scm","contents":"Git özelliklerini kullanmak istiyorsanız lütfen [ayarlar](command:workbench.action.openSettings?%5B%22git.enabled%22%5D) ayarında Git'i etkinleştirin.\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"!config.git.enabled"},{"view":"scm","contents":"Kod değişikliklerini izlemek ve başkalarıyla işbirliği yapmak için popüler bir kaynak denetimi sistemi olan Git'i yükleyin. [Git kılavuzlarımızda](https://aka.ms/vscode-scm) daha fazla bilgi edinin.","when":"config.git.enabled && git.missing"},{"view":"scm","contents":"[macOS için Git indirin](https://git-scm.com/download/mac)\r\nYükledikten sonra lütfen [yeniden yükleyin](command:workbench.action.reloadWindow) (veya [sorun giderin](command:git.showOutput)). Ek kaynak denetimi sağlayıcıları [Market’ten](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22) yüklenebilir.","when":"config.git.enabled && git.missing && isMac"},{"view":"scm","contents":"[Windows için Git indirin](https://git-scm.com/download/win)\r\nYükledikten sonra lütfen [yeniden yükleyin](command:workbench.action.reloadWindow) (veya [sorun giderin](command:git.showOutput)). Ek kaynak denetimi sağlayıcıları [Market’ten](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22) yüklenebilir.","when":"config.git.enabled && git.missing && isWindows"},{"view":"scm","contents":"Kaynak denetimi, Git’in yüklü olmasına bağlıdır.\r\n[Linux için Git indirin](https://git-scm.com/download/linux)\r\nYükledikten sonra lütfen [yeniden yükleyin](command:workbench.action.reloadWindow) (veya [sorun giderin](command:git.showOutput)). Ek kaynak denetimi sağlayıcıları [Market’ten](command:workbench.extensions.search?%22%40category%3A%5C%22scm%20providers%5C%22%22) yüklenebilir.","when":"config.git.enabled && git.missing && isLinux"},{"view":"scm","contents":"Git özelliklerini kullanmak için Git deposu içeren bir klasör açabilir veya URL'den klonlayabilirsiniz.\r\n[Klasörü Aç](command:vscode.openFolder)\r\n[Depoyu Klonla](command:git.clone)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && workbenchState == empty && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0","enablement":"git.state == initialized","group":"2_open@1"},{"view":"scm","contents":"Şu anda açık olan çalışma alanında Git depoları içeren klasör yok.\r\n[Çalışma Alanına Klasör Ekle](command:workbench.action.addRootFolder)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && workbenchState == workspace && workspaceFolderCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0","enablement":"git.state == initialized","group":"2_open@1"},{"view":"scm","contents":"Klasör, Git depoları için taranıyor...","when":"config.git.enabled && !git.missing && workbenchState == folder && workspaceFolderCount != 0 && git.state != initialized"},{"view":"scm","contents":"Çalışma alanı Git depoları için taranıyor...","when":"config.git.enabled && !git.missing && workbenchState == workspace && workspaceFolderCount != 0 && git.state != initialized"},{"view":"scm","contents":"Şu anda açık olan klasörde Git deposu yok. Git tarafından desteklenen kaynak denetimi özelliklerini etkinleştiren bir depo başlatabilirsiniz.\r\n[Depoyu Başlat](command:git.init?%5Btrue%5D)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && workbenchState == folder && scm.providerCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0 && remoteName != 'codespaces'","group":"5_scm@1"},{"view":"scm","contents":"Şu anda açık olan çalışma alanında Git depoları içeren klasör yok. Bir klasörde Git tarafından desteklenen kaynak denetimi özelliklerini etkinleştiren bir depo başlatabilirsiniz.\r\n[Depoyu Başlat](command:git.init)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && workbenchState == workspace && workspaceFolderCount != 0 && scm.providerCount == 0 && git.parentRepositoryCount == 0 && git.unsafeRepositoryCount == 0 && git.closedRepositoryCount == 0 && remoteName != 'codespaces'","group":"5_scm@1"},{"view":"scm","contents":"Çalışma alanının veya açık dosyaların üst klasörlerinde bir Git deposu bulundu.\r\n[Depoyu Aç](command:git.openRepositoriesInParentFolders)\r\nÇalışma alanının, açık dosyaların üst dizinlerindeki Git depolarının nasıl açılacağını denetlemek için [git.openRepositoryInParentFolders](command:workbench.action.openSettings?%5B%22git.openRepositoryInParentFolders%22%5D) ayarını kullanın. Daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-git-repository-in-parent-folders).","when":"config.git.enabled && !git.missing && git.state == initialized && git.parentRepositoryCount == 1"},{"view":"scm","contents":"Çalışma alanının veya açık dosyaların üst klasörlerinde Git depoları bulundu.\r\n[Depoyu Aç](command:git.openRepositoriesInParentFolders)\r\nÇalışma alanının üst klasörlerindeki veya açık dosyalardaki Git depolarının nasıl açılacağını denetlemek için [git.openRepositoryInParentFolders](command:workbench.action.openSettings?%5B%22git.openRepositoryInParentFolders%22%5D) ayarını kullanın. Daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-git-repository-in-parent-folders).","when":"config.git.enabled && !git.missing && git.state == initialized && git.parentRepositoryCount > 1"},{"view":"scm","contents":"Klasör geçerli kullanıcıdan farklı bir kişiye ait olduğundan algılanan Git deposu güvenli olmayabilir.\r\n[Güvenli Olmayan Depoları Yönet](command:git.manageUnsafeRepositories)\r\nGüvenli olmayan depolar hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-git-unsafe-repository).","when":"config.git.enabled && !git.missing && git.state == initialized && git.unsafeRepositoryCount == 1"},{"view":"scm","contents":"Klasörler geçerli kullanıcıdan farklı bir kişiye ait olduğundan algılanan Git depoları güvenli olmayabilir.\r\n[Güvenli Olmayan Depoları Yönet](command:git.manageUnsafeRepositories)\r\nGüvenli olmayan depolar hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-git-unsafe-repository).","when":"config.git.enabled && !git.missing && git.state == initialized && git.unsafeRepositoryCount > 1"},{"view":"scm","contents":"Daha önce kapatılan Git deposu bulundu.\r\n[Kapatılan Depoyu Yeniden Aç](command:git.reopenClosedRepositories)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && git.closedRepositoryCount == 1"},{"view":"scm","contents":"Daha önce kapatılan Git depoları bulundu.\r\n[Kapatılan Depoları Yeniden Aç](command:git.reopenClosedRepositories)\r\nVS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && !git.missing && git.state == initialized && git.closedRepositoryCount > 1"},{"view":"explorer","contents":"Depoyu yerel olarak klonlayabilirsiniz.\r\n[Depoyu Klonla](command:git.clone 'Git uzantısı etkinleştirildiğinde depoyu klonla')","when":"config.git.enabled && git.state == initialized && scm.providerCount == 0","group":"5_scm@1"},{"view":"explorer","contents":"VS Code’da Git ve kaynak denetimini kullanma hakkında daha fazla bilgi edinmek için [belgelerimizi okuyun](https://aka.ms/vscode-scm).","when":"config.git.enabled && git.state == initialized && scm.providerCount == 0","group":"5_scm@10"}]},"repository":{"type":"git","url":"https://github.com/microsoft/vscode.git"}},"location":{"$mid":1,"path":"/usr/lib/code/extensions/git","scheme":"file"},"isBuiltin":true,"targetPlatform":"undefined","isValid":true,"validations":[]},{"type":0,"identifier":{"id":"vscode.git-base"},"manifest":{"name":"git-base","displayName":"GIT Tabanı","description":"Git statik katkıları ve seçicileri.","version":"1.0.0","publisher":"vscode","license":"MIT","engines":{"vscode":"0.10.x"},"categories":["Other"],"activationEvents":["*"],"main":"./dist/extension.js","browser":"./dist/browser/extension.js","icon":"resources/icons/git.png","capabilities":{"virtualWorkspaces":true,"untrustedWorkspaces":{"supported":true}},"contributes":{"commands":[{"command":"git-base.api.getRemoteSources","title":{"value":"Uzak Kaynakları Al","original":"Get Remote Sources"},"category":"Git Base API"}],"menus":{"commandPalette":[{"command":"git-base.api.getRemoteSources","when":"false"}]},"languages":[{"id":"git-commit","aliases":["Git Commit Message","git-commit"],"filenames":["COMMIT_EDITMSG","MERGE_MSG"